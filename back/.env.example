# Dano back/ 运行所需环境变量(复制为 .env 或在 shell 里 export;真实 key 不要提交)

# ── pi 引擎的 LLM 凭证(仅经 env 注入,绝不写入代码/提交)──
# DeepSeek(OpenAI 兼容,用 pi 内置 deepseek provider):
DANO_PI_API_KEY=sk-你的DeepSeekKey
DANO_PI_PROVIDER=deepseek
DANO_PI_MODEL=deepseek-v4-flash        # 或 deepseek-v4-pro

# ── PostgreSQL(Phase 1 起需要)──
DANO_PG_DSN=postgresql://postgres:111111@localhost:5432/dano

# ── 三模型评审委员会(接入期发布前硬闸门;复用上面的 PI key + base_url)──
# 三审各用不同模型,发布闸门强制 distinct(model_id)=3;改模型名即可,无需改代码。
DANO_PI_BASE_URL=https://api.deepseek.com
DANO_REVIEW_ENABLED=1
DANO_REVIEW_MODEL_ACCEPTANCE=deepseek-reasoner   # 成果验收
DANO_REVIEW_MODEL_SECURITY=deepseek-v4-pro       # 漏洞检测
DANO_REVIEW_MODEL_COMPLIANCE=deepseek-v4-flash   # 合规审核
# 评审工程化:瞬时错误重试退避 + 急停开关(模型集群故障时临时关闭闸门应急发布)
DANO_REVIEW_MAX_RETRIES=2
DANO_REVIEW_RETRY_BACKOFF_S=1.0
# DANO_REVIEW_ENABLED=0                           # 运维急停:置 0 临时旁路评审闸门(审计留痕)

# ── 运行期凭证(二选一)──
# A) 真实 Vault(生产):配 token 即启用,require_vault=1 则强制(取不到不回退,fail closed)
DANO_VAULT_ADDR=http://localhost:8200
# DANO_VAULT_TOKEN=hvs.xxxxx
# DANO_REQUIRE_VAULT=1
# B) dev/试点:无 Vault 时用明文表(键=vault:// 后路径,如 demo/oa)
# DANO_RUNTIME_CREDENTIALS={"demo/oa": {"token": "..."}}

# 验收:
#   python agent_bridge.py          # stub 桥验收(不需 key)
#   python agent_bridge.py --real   # 真实模式验收(需上面的 key)
