# Dano 后端配置模板 —— 复制为 back/.env 后填真值。
# back/.env 已在 .gitignore,绝不入库;本模板只放占位符,可入库。
# 读取优先级:进程环境变量(DANO_ 前缀)> back/.env > config.py 默认值。

# 接入管道:new = 新链路主路径
DANO_ONBOARD_PIPELINE=new

# 自签证书 OA:1=关闭 TLS 证书校验(内网自签用);公网生产保持 0
DANO_INSECURE_TLS=1

# ── LLM 密钥(pi 编码 + 三模型评审,OpenAI 兼容)── 必填,密钥勿提交
DANO_PI_API_KEY=<在此填你的 API Key,勿提交>
DANO_PI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
DANO_PI_MODEL=claude-opus-4-8

# Agent Skill 生成参考目录：Windows 使用 doc；Linux 可配置 /opt/skillmanner/Dano/doc
# 生成时递归读取其中全部 .md 文件，不复制到产物。
DANO_SKILL_REFERENCE_DIR=doc

# ── 运行期 OA 凭证(可选;留空则接入时页面 token 临时进内存)──
# DANO_RUNTIME_CREDENTIALS={"你的租户/oa":{"token":"<OA token>"}}

# ── 运行期 Token 自动刷新 ──
# Linux timer 调内部接口的密钥；正式环境生成随机长值，勿提交。
DANO_TOKEN_REFRESH_KEY=<随机内部刷新密钥>
# 登录账号密码放 Vault；未启用 Vault 的单机环境可暂放 DANO_RUNTIME_CREDENTIALS。
# 正式环境必须启用 Vault 并禁止本地凭据回退：
# DANO_VAULT_ADDR=https://vault.example.internal:8200
# DANO_VAULT_TOKEN=<由安全的部署密钥注入，不要写入仓库>
# DANO_REQUIRE_VAULT=true
# DANO_RUNTIME_CREDENTIALS={"aaa/A-OA-login":{"tenant_name":"<租户>","username":"<账号>","password":"<密码>"}}
# 每个 tenant/subsystem 可按顺序配置多个 HTTP 登录来源；前一个失败会尝试下一个。
# 新 Token 必须先通过 verify_url 验证才会覆盖旧值。可信内网确需 HTTP 时显式配置 allow_insecure_http=true。
# DANO_TOKEN_REFRESH_SOURCES={"aaa/A-OA":[{"type":"password_http","url":"http://oa.example/admin-api/system/auth/login","verify_url":"http://oa.example/admin-api/system/auth/get-permission-info","allow_insecure_http":true,"credentials_ref":"vault://aaa/A-OA-login","body":{"tenantName":"{{tenant_name}}","username":"{{username}}","password":"{{password}}"},"token_path":"data.accessToken","header_name":"Authorization","token_prefix":"Bearer ","interval_seconds":1800}]}
