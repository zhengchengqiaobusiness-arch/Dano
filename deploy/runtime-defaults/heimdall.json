{
  "sandbox": {
    "enabled": true,
    "userNamespace": false,
    "paths": {
      ".": [
        { "mode": "write" },
        { "path": ".pi" }
      ],
      "/opt": [
        { "path": "$DANO_RUNTIME_DIR/.agents/skills" }
      ],
      "$DANO_RUNTIME_DIR/.pi": { "mode": "deny" },
      "$PI_CODING_AGENT_DIR": { "mode": "deny" },
      "~/.pi": {}
    },
    "env": {
      "allow": [
        "PATH",
        "HOME",
        "SHELL",
        "USER",
        "LOGNAME",
        "LANG",
        "LC_*",
        "TMPDIR",
        "DANO_URL",
        "DANO_TENANT_KEY"
      ],
      "deny": []
    }
  },
  "commandPolicies": [
    {
      "name": "block-root-deletion",
      "blocked": ["rm", "-rf", "/"],
      "message": "Deleting the root filesystem is blocked."
    }
  ]
}
