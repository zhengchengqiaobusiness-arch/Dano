{
  "sandbox": {
    "enabled": true,
    "userNamespace": false,
    "paths": {
      ".pi": { "mode": "deny" },
      "~/.pi": { "mode": "deny" }
    },
    "env": {
      "allow": [
        "PATH",
        "HOME",
        "SHELL",
        "USER",
        "LOGNAME",
        "LANG",
        "LC_*",
        "TMPDIR",
        "DANO_URL",
        "DANO_TENANT_KEY"
      ],
      "deny": []
    }
  },
  "commandPolicies": [
    {
      "name": "block-root-deletion",
      "blocked": ["rm", "-rf", "/"],
      "message": "Deleting the root filesystem is blocked."
    }
  ]
}
