{
  "name": "@dano/app",
  "version": "0.3.4",
  "private": true,
  "description": "Dano standalone browser application",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "dev": "node --import jiti/register ./src/main.ts",
    "start": "node ../../dist/bridge/standalone/main.js",
    "test": "vitest run --root ../.. --config vitest.config.ts"
  },
  "dependencies": {
    "@casualjim/pi-heimdall": "0.2.10",
    "@dano/bridge": "workspace:*",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.80.2"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "jiti": "^2.7.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
