DANO_HOST=0.0.0.0
DANO_PORT=8080
DANO_NGINX_PORT=18082
DANO_HTTPS_PORT=18443
DANO_EXPOSURE_MODE=http
DANO_DEFAULT_WORKSPACE_PATH=/tmp/dano
DANO_RUNTIME_DIR=/opt/dano/runtime-data
DANO_DEPLOY_DIR=/opt/dano/deploy
# Release Build writes DANO_NGINX_CONF and DANO_NGINX_SHARED_DIR into its
# Deploy Control Directory. Source-checkout runs select repository assets.
DANO_SECRETS_DIR=/opt/dano/deploy/.secrets
DANO_PRODUCT_NAME=Dano

# Optional trusted HS256 JWT identity. When omitted, Dano does not create a
# User Context and user-owned features remain unavailable.
# DANO_AUTH_JWT_SECRET=replace-with-a-long-random-secret
# DANO_AUTH_JWT_ISSUER=https://auth.example.com
# DANO_AUTH_JWT_AUDIENCE=dano
# DANO_AUTH_COOKIE_NAME=dano_auth
# Positive integer: maximum wait for model response headers, in milliseconds.
DANO_LLM_TIMEOUT_MS=300000

# Production compose starts a prebuilt image with --no-build.
DANO_IMAGE=dano-app:local

# Production release builds in /tmp/dano-build-* and copies deploy inputs here.
# DANO_REPO_URL=git@github.com:zhengchengqiaobusiness-arch/Dano.git
# DANO_GIT_REF=main

# Required only for https, both, and both-no-redirect-http exposure modes.
# DANO_TLS_CERT_PATH=/absolute/path/to/certificate.pem
# DANO_TLS_KEY_PATH=/absolute/path/to/private-key.pem

# Configure model provider credentials on the server only.
# XIAOMI_TOKEN_PLAN_CN_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
