{
  "name": "@dano/dano",
  "version": "0.1.89",
  "private": true,
  "description": "Dano P0 web LLM chat",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -C apps/dano build",
    "build:server": "pnpm -C apps/dano build:server",
    "build:web": "pnpm -C apps/dano build:web",
    "check": "pnpm -C apps/dano check",
    "check:server": "pnpm -C apps/dano check:server",
    "check:type": "pnpm run check:server",
    "check:web": "pnpm -C apps/dano check:web",
    "deploy:down": "node scripts/deploy-compose.mjs down",
    "deploy:logs": "node scripts/deploy-compose.mjs logs",
    "deploy:ps": "node scripts/deploy-compose.mjs ps",
    "deploy:release": "node scripts/deploy-release.mjs",
    "deploy:stop": "node scripts/deploy-compose.mjs stop",
    "deploy:up": "node scripts/deploy-compose.mjs up",
    "deploy:check-bash": "node scripts/check-bash-acceptance.mjs",
    "deploy:check-bash:container": "sh scripts/check-bash-acceptance-container.sh",
    "deploy:check-exposure": "node scripts/check-deploy-exposure.mjs",
    "dev:server": "pnpm -C apps/dano dev:server",
    "dev:web": "pnpm -C apps/dano dev:web",
    "secret:set": "node scripts/set-env-secret.mjs",
    "smoke:deploy": "node scripts/smoke-dano-deploy.mjs",
    "start": "pnpm -C apps/dano start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.8.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "workspaces": [
    "apps/*"
  ]
}
