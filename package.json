{
  "name": "@dano/dano",
  "version": "0.1.8",
  "private": true,
  "description": "Dano P0 web LLM chat",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:web",
    "build:bridge": "pnpm -C packages/bridge build",
    "build:server": "pnpm run build:bridge && pnpm -C apps/dano build",
    "build:svelte": "pnpm -C packages/svelte build",
    "build:web": "pnpm run build:svelte",
    "check": "pnpm run check:type && pnpm run check:web",
    "check:type": "tsc -p tsconfig.json --noEmit",
    "check:web": "pnpm -C packages/svelte check",
    "deploy:down": "node scripts/deploy-compose.mjs down",
    "deploy:logs": "node scripts/deploy-compose.mjs logs",
    "deploy:ps": "node scripts/deploy-compose.mjs ps",
    "deploy:release": "node scripts/deploy-release.mjs",
    "deploy:stop": "node scripts/deploy-compose.mjs stop",
    "deploy:up": "node scripts/deploy-compose.mjs up",
    "dev:bridge:standalone": "pnpm -C apps/dano dev",
    "dev:svelte": "pnpm -C packages/svelte dev",
    "dev:web": "pnpm run dev:svelte",
    "secret:set": "node scripts/set-env-secret.mjs",
    "smoke:deploy": "node scripts/smoke-dano-deploy.mjs",
    "start:bridge:standalone": "pnpm -C apps/dano start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.8.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@casualjim/pi-heimdall@0.2.10": "patches/@casualjim__pi-heimdall@0.2.10.patch"
    }
  }
}
