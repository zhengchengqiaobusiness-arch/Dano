{
  "name": "@dano/bridge",
  "version": "0.3.4",
  "private": true,
  "description": "HTTP/SSE RPC bridge server for Pi Web",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "test": "vitest run --root ../.. --config vitest.config.ts"
  },
  "dependencies": {
    "@casualjim/pi-heimdall": "0.2.10",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.80.2",
    "typebox": "1.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
