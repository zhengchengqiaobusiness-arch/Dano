{
  "name": "@dano/bridge",
  "version": "0.3.4",
  "private": true,
  "description": "HTTP/SSE RPC bridge server for Pi Web",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "dev:standalone": "node --import jiti/register ./src/standalone/main.ts",
    "start:standalone": "node ../../dist/bridge/standalone/main.js",
    "test": "vitest run --root ../.. --config vitest.config.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.74.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
